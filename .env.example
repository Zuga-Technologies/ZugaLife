# ZugaLife Environment Configuration
# Copy this to .env: cp .env.example .env

# ── AI Provider (optional) ────────────────────────────────────────────
# Venice AI key for therapist, journal insights, and meditation guidance.
# The app works without this — AI features will be disabled.
VENICE_API_KEY=

# ── Credit System (optional) ─────────────────────────────────────────
# Only needed when running as a ZugaApp plugin.
# In standalone mode, leave empty — defaults to unlimited.
ZUGAAPP_CREDITS_URL=
STUDIO_SERVICE_KEY=
CREDIT_FAIL_MODE=open

# ── Auth Mode ─────────────────────────────────────────────────────────
# "dev" = accepts any email without verification (default for standalone)
# "production" = requires email verification or Google OAuth
AUTH_MODE=dev
